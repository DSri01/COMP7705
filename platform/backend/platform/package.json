{
  "name": "platform",
  "version": "1.0.0",
  "description": "Stores the monolith platform service for container vulnerability management.",
  "main": "index.js",
  "scripts": {
    "compile": "npm run typecheck:test && tsc --project tsconfig.json",
    "cli:nvd-cve": "npm run compile && dotenv -e .dev.env -- node dist/cli/nvd-cve.js",
    "cli:epss-cve": "npm run compile && dotenv -e .dev.env -- node dist/cli/epss-cve.js",
    "cli:container-scan": "npm run compile && dotenv -e .dev.env -- node dist/cli/container-scan.js",
    "cli:platform-assistant": "npm run compile && dotenv -e .dev.env -- node dist/cli/agents/platform-assistant/index.js",
    "cli:summary-generation": "npm run compile && dotenv -e .dev.env -- node dist/cli/agents/summary-generation/index.js",
    "cli:advice-generation": "npm run compile && dotenv -e .dev.env -- node dist/cli/agents/advice-generation/index.js",
    "cli:agent-tui": "npm run compile && dotenv -e .dev.env -- node dist/cli/agent-tui/index.js",
    "cli:web-fetch": "npm run compile && node dist/cli/web/fetch-and-parse.js",
    "cli:web-search": "npm run compile && dotenv -e .dev.env -- node dist/cli/web/search.js",
    "dev": "npm run compile && dotenv -e .dev.env -- npm run start",
    "start": "node dist/index.js",
    "test": "npm run typecheck:all && jest",
    "typecheck:src": "tsc --noEmit --project tsconfig.json",
    "typecheck:test": "tsc --noEmit --project tsconfig.test.json",
    "typecheck:all": "npm run typecheck:src && npm run typecheck:test"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@nestjs/cli": "^11.0.19",
    "@nestjs/schematics": "^11.0.10",
    "@nestjs/testing": "^11.1.19",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@langchain/core": "^1.1.44",
    "@langchain/langgraph": "^1.3.0",
    "@langchain/ollama": "^1.2.7",
    "@langchain/openai": "^1.4.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/swagger": "^11.2.7",
    "@nestjs/typeorm": "^11.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "firecrawl": "^4.25.2",
    "nestjs-pino": "^4.6.1",
    "node-html-markdown": "^2.0.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.28",
    "zod": "^4.3.6"
  }
}
