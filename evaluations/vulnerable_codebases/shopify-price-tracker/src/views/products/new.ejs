<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Add Product - Price Tracker</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav>
    <div class="nav-brand">Price Tracker</div>
    <div class="nav-links">
      <a href="/">Dashboard</a>
      <a href="/products">Products</a>
      <a href="/alerts">Alerts</a>
    </div>
  </nav>

  <main class="container">
    <h1>Add Product</h1>
    <form method="POST" action="/products">
      <div class="form-group">
        <label for="name">Product Name</label>
        <input type="text" id="name" name="name" required>
      </div>
      <div class="form-group">
        <label for="url">Product URL</label>
        <input type="url" id="url" name="url" required placeholder="https://shop.example.com/products/...">
      </div>
      <div class="form-group">
        <label for="target_price">Target Price ($)</label>
        <input type="number" id="target_price" name="target_price" step="0.01" required>
      </div>
      <button type="submit" class="btn">Add Product</button>
      <a href="/products" class="btn btn-secondary">Cancel</a>
    </form>
  </main>
</body>
</html>
