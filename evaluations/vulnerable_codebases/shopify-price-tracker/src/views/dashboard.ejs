<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Price Tracker Dashboard</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav>
    <div class="nav-brand">Price Tracker</div>
    <div class="nav-links">
      <a href="/">Dashboard</a>
      <a href="/products">Products</a>
      <a href="/alerts">Alerts</a>
    </div>
  </nav>

  <main class="container">
    <div class="stats-grid">
      <div class="stat-card">
        <span class="stat-value"><%= stats.tracked || 0 %></span>
        <span class="stat-label">Tracked Products</span>
      </div>
      <div class="stat-card">
        <span class="stat-value"><%= stats.below_target || 0 %></span>
        <span class="stat-label">Below Target</span>
      </div>
      <div class="stat-card">
        <span class="stat-value">$<%= stats.avg_price || '0.00' %></span>
        <span class="stat-label">Average Price</span>
      </div>
    </div>

    <section class="section">
      <h2>Recent Price Changes</h2>
      <table>
        <thead>
          <tr><th>Product</th><th>Old Price</th><th>New Price</th><th>Detected</th></tr>
        </thead>
        <tbody>
          <% recentChanges.forEach(change => { %>
          <tr>
            <td><%= change.name %></td>
            <td>$<%= change.old_price %></td>
            <td>$<%= change.new_price %></td>
            <td><%= new Date(change.detected_at).toLocaleString() %></td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </section>

    <section class="section">
      <h2>Products</h2>
      <div class="product-grid">
        <% products.forEach(product => { %>
        <div class="product-card">
          <h3><%= product.name %></h3>
          <p class="price">$<%= product.last_price || '—' %></p>
          <a href="/products/<%= product.id %>">View Details</a>
        </div>
        <% }); %>
      </div>
    </section>
  </main>

  <script src="/socket.io/socket.io.js"></script>
  <script>
    const socket = io();
    socket.on('price-update', (data) => {
      console.log('Price update:', data);
      location.reload();
    });
  </script>
</body>
</html>
